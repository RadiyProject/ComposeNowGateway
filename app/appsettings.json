{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Urls": "http://+:5001",
  "Jwt": {
    "Issuer": "ComposeNowSite",
    "Audience": "ComposeNowClients"
  },
  "Gateway": {
    "SiteBaseUrl": "http://site:5001",
    "PluginsWebSocketUrl": "ws://plugins:5001/ws",
    "SessionTtlMinutes": 60
  }
}
